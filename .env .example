# Copy locally as ".env" for testing, or type these into Render's
# Environment Variables dashboard for the live deployment.

# Log into app.payhero.co.ke → API Keys menu → follow "How To Get Basic
# Auth Token From UI" in their docs. Paste the WHOLE value including the
# word "Basic " at the start, e.g: Basic bXlfdXNlcm5hbWU6bXlfcGFzc3dvcmQ=
PAYHERO_AUTH_TOKEN=Basic REPLACE_WITH_YOUR_FULL_TOKEN

# app.payhero.co.ke → Payment Channels → My Payment Channels → the ID
# number next to your registered paybill/till
PAYHERO_CHANNEL_ID=REPLACE_WITH_YOUR_CHANNEL_ID

# Must be your Render backend's real public URL + /api/payhero/callback
# e.g. https://efootball-vote-backend.onrender.com/api/payhero/callback
PAYHERO_CALLBACK_URL=REPLACE_WITH_YOUR_CALLBACK_URL

PRICE_PER_VOTE=20
PORT=5000
